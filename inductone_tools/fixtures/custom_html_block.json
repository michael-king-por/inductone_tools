  {
    "docstatus": 0,
    "doctype": "Custom HTML Block",
    "html": "<div class=\"por-guidance-static\"><div class=\"por-eyebrow\">How to run a Build</div><div class=\"por-cards\"><div><strong>1. Configure</strong><span>Load released Configuration Options, select the required groups, and generate the Configured BOM Snapshot.</span></div><div><strong>2. Prepare handoff</strong><span>Create the Configuration Order, generate the release package, allocate the IND serial, and release to the builder.</span></div><div><strong>3. Review completion</strong><span>Review the returned Build Completion workbook, then accept it to create the As-Built Record and Instance.</span></div></div></div>",
    "name": "Operations Guidance Panel",
    "private": 0,
    "script": "",
    "style": ".por-guidance-static{font-family:Arial,sans-serif;border:1px solid #EAECF0;border-radius:10px;background:#FFFFFF;padding:14px;margin-bottom:12px}.por-eyebrow{font-size:11px;text-transform:uppercase;letter-spacing:.7px;color:#667085;font-weight:800;margin-bottom:10px}.por-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px}.por-cards div{border:1px solid #EAECF0;border-radius:8px;background:#F9FAFB;padding:12px}.por-cards strong{display:block;font-size:13px;color:#101828;margin-bottom:5px}.por-cards span{display:block;font-size:12px;color:#475467;line-height:1.45}"
