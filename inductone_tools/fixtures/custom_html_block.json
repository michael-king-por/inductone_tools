    "style": ".por-hero{font-family:Arial,sans-serif;background:#1794CE;padding:16px 22px;display:flex;align-items:center;gap:14px;border-radius:10px;margin-bottom:14px;color:#fff}.por-logo{width:42px;height:42px;background:#fff;border-radius:8px;display:flex;align-items:center;justify-content:center;flex:0 0 auto;padding:5px}.por-logo img{width:100%;height:100%;object-fit:contain}.por-title{font-size:18px;font-weight:800;line-height:1.2}.por-subtitle{font-size:12px;color:#D6ECF7;margin-top:3px}.por-pill{margin-left:auto;font-size:11px;color:#D6ECF7;border:1px solid #5BB6E0;border-radius:999px;padding:4px 10px;white-space:nowrap}"
